# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=lingospark

# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Server
PORT=3001

# Speech Provider: 'web' (browser-native), 'google' (Google Cloud STT), or 'openai' (OpenAI Whisper)
SPEECH_PROVIDER=openai
# GOOGLE_CLOUD_API_KEY=your-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
